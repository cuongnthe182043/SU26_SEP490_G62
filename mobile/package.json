{
  "name": "mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "dev": "expo start",
    "start:clear": "expo start --clear",
    "start:lan": "expo start --host lan",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:android": "eas build -p android --profile preview",
    "build:ios": "eas build -p ios --profile preview",
    "build:all": "eas build --profile preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-community/datetimepicker": "8.4.4",
    "@tamagui/babel-plugin": "1.144.4",
    "@tamagui/config": "1.144.4",
    "@tamagui/core": "1.144.4",
    "@tamagui/font-inter": "1.144.4",
    "@tamagui/metro-plugin": "1.144.4",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.34",
    "expo-auth-session": "~7.0.11",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.12",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.18",
    "expo-web-browser": "~15.0.11",
    "lucide-react-native": "^1.17.0",
    "phosphor-react-native": "^3.0.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "tamagui": "1.144.4"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^14.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.9.1",
    "@types/react": "~19.1.0",
    "expo-module-scripts": "^1.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "jest-html-reporters": "^3.1.7",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "./jest.setup.js"
    ],
    "moduleNameMapper": {
      "^test-renderer$": "<rootDir>/node_modules/react-test-renderer",
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|react-navigation|@react-navigation/.*|tamagui|@tamagui/.*|lucide-react-native|phosphor-react-native)"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.[jt]s?(x)"
    ],
    "reporters": [
      "default",
      [
        "jest-html-reporters",
        {
          "publicPath": "./test-report",
          "filename": "index.html",
          "openReport": false,
          "pageTitle": "G62 Mobile Test Report"
        }
      ]
    ]
  }
}
